{
  "apiVersion": 2,
  "name": "vp/portfolio-gallery",
  "title": "Portfolio Gallery",
  "category": "widgets",
  "icon": "grid-view",
  "description": "Display a portfolio gallery.",
  "editorScript": "vp-portfolio-gallery-block",
  "attributes": {
    "ids": {
      "type": "string",
      "default": ""
    },
    "taxonomy": { "type": "string", "default": "video-format" },
