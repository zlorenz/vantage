    "bodyHtml": "<!-- wp:wp-bootstrap-blocks/container -->\n<!-- wp:wp-bootstrap-blocks/row {\"template\":\"custom\"} -->\n<!-- wp:wp-bootstrap-blocks/column {\"sizeLg\":3,\"sizeMd\":2,\"sizeSm\":1} /-->\n\n<!-- wp:wp-bootstrap-blocks/column {\"sizeLg\":6,\"sizeMd\":8,\"sizeSm\":10} -->\n<!-- wp:freeform -->\n<h3><a title=\"Send us an email\" href=\"mailto:info@vantage.pictures\">info@vantage.pictures</a></h3>\n<p>Vantage Pictures is a global commercial film production company working with brands worldwide. For project inquiries, production partnerships, or general questions, contact our team and we’ll respond promptly.</p>\n<!-- /wp:freeform -->\n<!-- /wp:wp-bootstrap-blocks/column -->\n<!-- /wp:wp-bootstrap-blocks/row -->\n<!-- /wp:wp-bootstrap-blocks/container -->\n\n<!-- wp:wp-bootstrap-blocks/container -->\n<!-- wp:wp-bootstrap-blocks/row {\"template\":\"1-1-1\"} -->\n<!-- wp:wp-bootstrap-blocks/column {\"sizeMd\":4} -->\n<!-- wp:freeform -->\n<h2>Bay Area</h2>\n<p>1532 Elm Ave.<br />Richmond, CA 94805</p>\n<!-- /wp:freeform -->\n<!-- /wp:wp-bootstrap-blocks/column -->\n\n<!-- wp:wp-bootstrap-blocks/column {\"sizeMd\":4} -->\n<!-- wp:freeform -->\n<h2>Hong Kong</h2>\n<div>\n<p class=\"address\">Tung Chiu Commercial Centre, Rooms 1703-1704<br />193 Lockhart Road<br />Wan Chai, Hong Kong</p>\n</div>\n<p><a title=\"Give us a call\" href=\"tel:+85257229444\">+852 5722 9444</a></p>\n<!-- /wp:freeform -->\n<!-- /wp:wp-bootstrap-blocks/column -->\n\n<!-- wp:wp-bootstrap-blocks/column {\"sizeMd\":4} -->\n<!-- wp:freeform -->\n<h2>Vietnam</h2>\n<p class=\"address\">67/26 Hoàng Hoa Thám<br />Phường 6, Bình Thạnh<br />TP Hồ Chí Minh, Vietnam</p>\n<p><a title=\"Give us a call\" href=\"tel:+84327202070\">+84 32 7202070</a></p>\n<!-- /wp:freeform -->\n<!-- /wp:wp-bootstrap-blocks/column -->\n<!-- /wp:wp-bootstrap-blocks/row -->\n<!-- /wp:wp-bootstrap-blocks/container -->\n\n<!-- wp:block {\"ref\":3781} /-->",
