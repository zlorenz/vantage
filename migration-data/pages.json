    "featuredImageWpId": 3627,
    "bodyHtml": "<!-- wp:wp-bootstrap-blocks/container -->\n<!-- wp:heading {\"textAlign\":\"center\",\"level\":1} -->\n<h1 class=\"wp-block-heading has-text-align-center\" id=\"h-a-bit-of-our-work\"><span class=\"vp-outline\">A Bit of</span> Our Work</h1>\n<!-- /wp:heading -->\n\n<!-- wp:vp/portfolio-gallery {\"ids\":\"3519,3524,3504,3283,3239,3276,3499,3518,3173,3101,2059,3040\",\"cols\":3,\"gutter\":3} /-->\n<!-- /wp:wp-bootstrap-blocks/container -->\n\n<!-- wp:wp-bootstrap-blocks/container -->\n<!-- wp:wp-bootstrap-blocks/row {\"template\":\"custom\",\"metadata\":{\"name\":\"Row (10-Column Centered)\"}} -->\n<!-- wp:wp-bootstrap-blocks/column {\"sizeSm\":10,\"metadata\":{\"name\":\"col-sm-10\"},\"className\":\"offset-sm-1\"} -->\n<!-- wp:heading {\"level\":1} -->\n<h1 class=\"wp-block-heading\" id=\"h-global-commercial-film-production-for-ambitious-brands\">Global Commercial Film Production <span class=\"vp-outline\">for Ambitious Brands</span></h1>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph -->\n<p>Vantage Pictures is a globally operating commercial film production company creating cinematic brand films, product launch campaigns, and high-impact technology commercials for ambitious companies worldwide. We collaborate with fast-growing innovators and established global brands to craft visually refined, strategically grounded films that elevate product storytelling and brand identity.</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph -->\n<p>A core specialty of our studio is helping Asian technology brands — particularly from China — connect with Western audiences through premium, internationally positioned campaigns. From robotics and AI to consumer electronics and next-generation hardware, we translate complex innovation into emotionally resonant visual storytelling.</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph -->\n<p>Beyond technology, our portfolio spans lifestyle, automotive, energy, sport, and documentary-driven brand films — all executed with disciplined production standards, cinematic craft, and cross-border expertise.</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:wp-bootstrap-blocks/button {\"url\":\"http://localhost:8888/vantage-local/about/\",\"text\":\"Learn More About Us\"} /-->\n<!-- /wp:wp-bootstrap-blocks/column -->\n<!-- /wp:wp-bootstrap-blocks/row -->\n<!-- /wp:wp-bootstrap-blocks/container -->\n\n<!-- wp:wp-bootstrap-blocks/container -->\n<!-- wp:heading {\"textAlign\":\"center\",\"level\":1} -->\n<h1 class=\"wp-block-heading has-text-align-center\" id=\"h-brands-nbsp-we-work-with\">Brands&nbsp;<span class=\"vp-outline\">We Work With</span></h1>\n<!-- /wp:heading -->\n\n<!-- wp:gallery {\"columns\":4,\"linkTo\":\"none\",\"sizeSlug\":\"full\",\"className\":\"brand-logos\"} -->\n<figure class=\"wp-block-gallery has-nested-images columns-4 is-cropped brand-logos\"><!-- wp:image {\"id\":45,\"sizeSlug\":\"full\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-full\"><img src=\"http://localhost:8888/vantage-local/wp-content/uploads/2021/06/cnn.png\" alt=\"CNN logo white transparent\" class=\"wp-image-45\"/></figure>\n<!-- /wp:image -->\n\n<!-- wp:image {\"id\":52,\"sizeSlug\":\"full\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-full\"><img src=\"http://localhost:8888/vantage-local/wp-content/uploads/2021/06/oneplus.png\" alt=\"OnePlus logo white transparent\" class=\"wp-image-52\"/></figure>\n<!-- /wp:image -->\n\n<!-- wp:image {\"id\":49,\"sizeSlug\":\"full\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-full\"><img src=\"http://localhost:8888/vantage-local/wp-content/uploads/2021/06/hyundai.png\" alt=\"Hyundai logo white transparent\" class=\"wp-image-49\"/></figure>\n<!-- /wp:image -->\n\n<!-- wp:image {\"id\":55,\"sizeSlug\":\"full\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-full\"><img src=\"http://localhost:8888/vantage-local/wp-content/uploads/2021/06/samsung.png\" alt=\"Samsung logo white transparent\" class=\"wp-image-55\"/></figure>\n<!-- /wp:image -->\n\n<!-- wp:image {\"id\":48,\"sizeSlug\":\"full\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-full\"><img src=\"http://localhost:8888/vantage-local/wp-content/uploads/2021/06/huawei.png\" alt=\"Huawei logo white transparent\" class=\"wp-image-48\"/></figure>\n<!-- /wp:image -->\n\n<!-- wp:image {\"id\":54,\"sizeSlug\":\"full\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-full\"><img src=\"http://localhost:8888/vantage-local/wp-content/uploads/2021/06/realme.png\" alt=\"realme logo white transparent\" class=\"wp-image-54\"/></figure>\n<!-- /wp:image -->\n\n<!-- wp:image {\"id\":47,\"sizeSlug\":\"full\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-full\"><img src=\"http://localhost:8888/vantage-local/wp-content/uploads/2021/06/hasselblad.png\" alt=\"Hasselblad logo white transparent\" class=\"wp-image-47\"/></figure>\n<!-- /wp:image -->\n\n<!-- wp:image {\"id\":46,\"sizeSlug\":\"full\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-full\"><img src=\"http://localhost:8888/vantage-local/wp-content/uploads/2021/06/dji.png\" alt=\"DJI logo white transparent\" class=\"wp-image-46\"/></figure>\n<!-- /wp:image -->\n\n<!-- wp:image {\"id\":44,\"sizeSlug\":\"full\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-full\"><img src=\"http://localhost:8888/vantage-local/wp-content/uploads/2021/06/braun.png\" alt=\"Braun logo white transparent\" class=\"wp-image-44\"/></figure>\n<!-- /wp:image -->\n\n<!-- wp:image {\"id\":56,\"sizeSlug\":\"full\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-full\"><img src=\"http://localhost:8888/vantage-local/wp-content/uploads/2021/06/the-north-face.png\" alt=\"The North Face logo white transparent\" class=\"wp-image-56\"/></figure>\n<!-- /wp:image -->\n\n<!-- wp:image {\"id\":51,\"sizeSlug\":\"full\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-full\"><img src=\"http://localhost:8888/vantage-local/wp-content/uploads/2021/06/jw-marriott.png\" alt=\"JW Marriott logo white transparent\" class=\"wp-image-51\"/></figure>\n<!-- /wp:image -->\n\n<!-- wp:image {\"id\":3035,\"sizeSlug\":\"full\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-full\"><img src=\"http://localhost:8888/vantage-local/wp-content/uploads/2022/12/toyota.png\" alt=\"Toyota logo white transparent\" class=\"wp-image-3035\"/></figure>\n<!-- /wp:image -->\n\n<!-- wp:image {\"id\":3034,\"sizeSlug\":\"full\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-full\"><img src=\"http://localhost:8888/vantage-local/wp-content/uploads/2022/12/png.png\" alt=\"Procter &amp; Gamble logo white transparent\" class=\"wp-image-3034\"/></figure>\n<!-- /wp:image -->\n\n<!-- wp:image {\"id\":59,\"sizeSlug\":\"full\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-full\"><img src=\"http://localhost:8888/vantage-local/wp-content/uploads/2021/06/zhiyun.png\" alt=\"Zhiyun logo white transparent\" class=\"wp-image-59\"/></figure>\n<!-- /wp:image -->\n\n<!-- wp:image {\"id\":3032,\"sizeSlug\":\"full\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-full\"><img src=\"http://localhost:8888/vantage-local/wp-content/uploads/2022/12/coca-cola.png\" alt=\"Coca Cola logo white transparent\" class=\"wp-image-3032\"/></figure>\n<!-- /wp:image -->\n\n<!-- wp:image {\"id\":57,\"sizeSlug\":\"full\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-full\"><img src=\"http://localhost:8888/vantage-local/wp-content/uploads/2021/06/unilever.png\" alt=\"Unilever logo white transparent\" class=\"wp-image-57\"/></figure>\n<!-- /wp:image --></figure>\n<!-- /wp:gallery -->\n<!-- /wp:wp-bootstrap-blocks/container -->\n\n<!-- wp:block {\"ref\":3781} /-->",
