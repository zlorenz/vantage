  {
    "wpId": 3778,
    "title": "About",
    "titleZh": "关于我们",
    "slug": "about",
    "slugZh": "关于",
    "showHeroHeader": true,
    "heroTitle": "About <span class=\"vp-outline\">Us</span>",
    "featuredImageWpId": 2367,
    "bodyHtml": "<!-- wp:wp-bootstrap-blocks/container -->\n<!-- wp:wp-bootstrap-blocks/row {\"className\":\"mt-5\"} -->\n<!-- wp:wp-bootstrap-blocks/column {\"sizeMd\":8,\"sizeSm\":10,\"className\":\"offset-md-2 offset-sm-1\"} -->\n<!-- wp:heading {\"level\":1} -->\n<h1 class=\"wp-block-heading\">Who <span class=\"vp-outline\">We Are</span></h1>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph -->\n<p>Vantage Pictures is a global commercial film production company creating cinematic brand films, product launch campaigns, and technology-driven advertising for ambitious brands worldwide. While our studio operates internationally, we have developed a strong specialization in helping Asian technology companies — particularly from China — position their products for Western audiences through premium, internationally competitive campaigns.</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph -->\n<p>Our team combines strategic messaging, disciplined production execution, and refined cinematic craft across industries including AI and robotics, consumer electronics, automotive, energy, lifestyle, and documentary-driven brand storytelling. With extensive cross-border experience, we bridge markets, cultures, and creative standards to deliver work that performs globally.</p>\n<!-- /wp:paragraph -->\n<!-- /wp:wp-bootstrap-blocks/column -->\n\n<!-- wp:wp-bootstrap-blocks/column {\"sizeMd\":6} /-->\n<!-- /wp:wp-bootstrap-blocks/row -->\n<!-- /wp:wp-bootstrap-blocks/container -->\n\n<!-- wp:wp-bootstrap-blocks/container -->\n<!-- wp:heading {\"textAlign\":\"center\",\"level\":1} -->\n<h1 class=\"wp-block-heading has-text-align-center\"><span class=\"vp-outline\">Our</span> Team</h1>\n<!-- /wp:heading -->\n\n<!-- wp:gallery {\"columns\":4,\"linkTo\":\"none\"} -->\n<figure class=\"wp-block-gallery has-nested-images columns-4 is-cropped\"><!-- wp:image {\"id\":2851,\"sizeSlug\":\"large\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-large\"><img src=\"http://localhost:8888/vantage-local/wp-content/uploads/2022/05/alexis-odiowei.jpg\" alt=\"Headshot of Alexis Odiowei, Managing Director at Vantage Pictures\" class=\"wp-image-2851\"/><figcaption class=\"wp-element-caption\">Alexis Odiowei</figcaption></figure>\n<!-- /wp:image -->\n\n<!-- wp:image {\"id\":2856,\"sizeSlug\":\"large\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-large\"><img src=\"http://localhost:8888/vantage-local/wp-content/uploads/2022/05/paul-moore.jpg\" alt=\"Headshot of Paul Moore, Creative Director at Vantage Pictures\" class=\"wp-image-2856\"/><figcaption class=\"wp-element-caption\">Paul Moore</figcaption></figure>\n<!-- /wp:image -->\n\n<!-- wp:image {\"id\":2860,\"sizeSlug\":\"large\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-large\"><img src=\"http://localhost:8888/vantage-local/wp-content/uploads/2022/05/zacharia-lorenz.jpg\" alt=\"Headshot of Zacharia Lorenz, Marketing Director at Vantage Pictures\" class=\"wp-image-2860\"/><figcaption class=\"wp-element-caption\">Zacharia Lorenz</figcaption></figure>\n<!-- /wp:image -->\n\n<!-- wp:image {\"id\":2853,\"sizeSlug\":\"large\",\"linkDestination\":\"none\"} -->\n<figure class=\"wp-block-image size-large\"><img src=\"http://localhost:8888/vantage-local/wp-content/uploads/2022/05/james-duong.jpg\" alt=\"Headshot of James Duong, Executive Producer at Vantage Pictures\" class=\"wp-image-2853\"/><figcaption class=\"wp-element-caption\">James Duong</figcaption></figure>\n<!-- /wp:image --></figure>\n<!-- /wp:gallery -->\n<!-- /wp:wp-bootstrap-blocks/container -->\n\n<!-- wp:block {\"ref\":3781} /-->",
