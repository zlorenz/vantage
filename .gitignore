# --------------------------------------------------
# WordPress Core (ignore)
# --------------------------------------------------

/wp-admin/
/wp-includes/
/xmlrpc.php
/wp-*.php
/index.php
/license.txt
/readme.html

# --------------------------------------------------
# WordPress Configuration
# --------------------------------------------------

wp-config.php
.htaccess

# --------------------------------------------------
# Uploads (media files)
# --------------------------------------------------

/wp-content/uploads/

# --------------------------------------------------
# Cache
# --------------------------------------------------

/wp-content/cache/

# --------------------------------------------------
# Logs
# --------------------------------------------------

*.log

# --------------------------------------------------
# macOS / system junk
# --------------------------------------------------

.DS_Store
Thumbs.db

# --------------------------------------------------
# Node dependencies
# --------------------------------------------------

/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --------------------------------------------------
# WordPress plugins
# Ignore ALL plugins except ones you explicitly whitelist
# --------------------------------------------------

/wp-content/plugins/*

# WPvivid backup plugin
/wp-content/wpvividbackups/

# Allow custom plugins to be tracked
!/wp-content/plugins/vp-content-types
!/wp-content/plugins/vp-lark-client-brief

# --------------------------------------------------
# WordPress themes
# Ignore all themes except your custom child theme
# --------------------------------------------------

/wp-content/themes/*

# Allow your child theme
!/wp-content/themes/vantagepictures-child

# --------------------------------------------------
# Environment variables — NEVER commit these
# --------------------------------------------------

.env*
.env.local
.env*.local

# --------------------------------------------------
# Next.js
# --------------------------------------------------

/.next/
/out/
/build

# testing
/coverage

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# misc
*.pem

# --------------------------------------------------
# Sanity
# --------------------------------------------------

.sanity/

# --------------------------------------------------
# WordPress legacy reference files
# (kept locally for audit/migration reference only)
# --------------------------------------------------

/wp-content/themes/vantagepictures-child/
/wp-content/uploads/
