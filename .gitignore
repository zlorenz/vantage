# --------------------------------------------------
# WordPress Core (ignore)
# --------------------------------------------------

/wp-admin/
/wp-includes/
/xmlrpc.php
/wp-*.php
/index.php
/license.txt
/readme.html

# --------------------------------------------------
# WordPress Configuration
# --------------------------------------------------

wp-config.php
.htaccess

# --------------------------------------------------
# Uploads (media files)
# --------------------------------------------------

/wp-content/uploads/

# --------------------------------------------------
# Cache
# --------------------------------------------------

/wp-content/cache/

# --------------------------------------------------
# Logs
# --------------------------------------------------

*.log

# --------------------------------------------------
# macOS / system junk
# --------------------------------------------------

.DS_Store
Thumbs.db

# --------------------------------------------------
# Node dependencies (if you ever add them)
/node_modules/

# --------------------------------------------------
# WordPress plugins
# Ignore ALL plugins except ones you explicitly whitelist
# --------------------------------------------------

/wp-content/plugins/*

# WPvivid backup plugin
/wp-content/wpvividbackups/

# Allow custom plugins to be tracked
!/wp-content/plugins/vp-content-types
!/wp-content/plugins/vp-lark-client-brief

# --------------------------------------------------
# WordPress themes
# Ignore all themes except your custom child theme
# --------------------------------------------------

/wp-content/themes/*

# Allow your child theme
!/wp-content/themes/vantagepictures-child