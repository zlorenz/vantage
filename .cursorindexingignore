# =========================================================
# Cursor indexing ignore for Vantage local WordPress project
# Focus indexing on active theme code and selected reference sources
# =========================================================

# ---------------------------------------------------------
# Git internals
# ---------------------------------------------------------
/.git/**

# ---------------------------------------------------------
# WordPress generated / backup / upload content
# ---------------------------------------------------------
/wp-content/uploads/**
/wp-content/upgrade/**
/wp-content/upgrade-temp-backup/**
/wp-content/wpvividbackups/**
/wp-content/wpvivid_staging/**

# ---------------------------------------------------------
# WordPress core
# Ignore most of it, but allow specific CSS/block reference areas
# ---------------------------------------------------------
/wp-admin/**
!/wp-admin/css/**
!/wp-admin/css/**/*.css

/wp-includes/**
!/wp-includes/css/dist/**
!/wp-includes/css/dist/**/*.css
!/wp-includes/blocks/**

# ---------------------------------------------------------
# Ignore all plugins by default
# ---------------------------------------------------------
/wp-content/plugins/**

# ---------------------------------------------------------
# Allowlist plugins we actively reference
# ---------------------------------------------------------
!/wp-content/plugins/advanced-custom-fields-pro/**
!/wp-content/plugins/gravityforms/**
!/wp-content/plugins/uixpress/**
!/wp-content/plugins/vp-content-types/**
!/wp-content/plugins/wp-bootstrap-blocks/**
!/wp-content/plugins/wordpress-seo/**

# ---------------------------------------------------------
# Trim heavy folders inside allowed plugins
# ---------------------------------------------------------
/wp-content/plugins/advanced-custom-fields-pro/vendor/**
/wp-content/plugins/gravityforms/vendor/**
/wp-content/plugins/gravityforms/node_modules/**
/wp-content/plugins/uixpress/**/vendor/**
/wp-content/plugins/uixpress/**/node_modules/**
/wp-content/plugins/uixpress/**/.vite/**
/wp-content/plugins/wordpress-seo/vendor/**
/wp-content/plugins/wordpress-seo/vendor_prefixed/**
/wp-content/plugins/wordpress-seo/packages/**
/wp-content/plugins/wordpress-seo/node_modules/**

# ---------------------------------------------------------
# Ignore local dependency/cache junk anywhere
# Be careful with dist/build because many WP plugins/themes
# store useful compiled assets there
# ---------------------------------------------------------
**/node_modules/**
**/.vite/**
**/.cache/**
**/coverage/**
**/*.map

# ---------------------------------------------------------
# OS junk
# ---------------------------------------------------------
**/.DS_Store
**/Thumbs.db

# ---------------------------------------------------------
# Themes
# Keep both parent and child indexed
# ---------------------------------------------------------
!/wp-content/themes/vantagepictures/**
!/wp-content/themes/vantagepictures-child/**